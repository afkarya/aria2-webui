# Copy this file to .env and edit as needed

# aria2 JSON-RPC endpoint
ARIA2_RPC=http://localhost:6800/jsonrpc

# aria2 RPC secret (must match --rpc-secret in your aria2 daemon)
ARIA2_SECRET=

# Port for aria2c (if managed by the web UI)
ARIA2_PORT=6800

# Task persistence file
DB_FILE=aria_tasks.json

# Seconds before aborting a stalled download
DOWNLOAD_STALL_SECONDS=300

# Web UI listen address and port
HOST=127.0.0.1
PORT=5000